# Copy to .env for local development or deployment.

# Required for production. Generate with: openssl rand -hex 32
JWT_SECRET=

# Set to 1 only for local development when you want a seeded test account.
TAGNOTE_TEST_MODE=0

# Set to 1 only for local development if JWT_SECRET is empty.
TAGNOTE_ALLOW_DEV_SECRET=0

# Optional production domain used by compose/Caddy examples.
TAGNOTE_DOMAIN=notes.example.com

# Optional public base URL used in email links.
BASE_URL=http://localhost:3000

# Optional admin account email.
ADMIN_EMAIL=

# Static bearer token for non-admin access to /status and /metrics.
# Required for monitoring jobs that scrape /metrics without an admin JWT.
OPERATIONAL_BEARER_TOKEN=

# Optional Google OAuth client ID. Accepts a comma-separated list of accepted
# token audiences (e.g. web client id + iOS client id).
GOOGLE_CLIENT_ID=

# Optional Sign in with Apple accepted token audiences, comma-separated: the
# native app bundle id (com.tag-note.tagnote) and/or the web Services ID
# (com.tag-note.web). Leave empty to disable Apple login.
APPLE_CLIENT_ID=

# Optional Sign in with Apple on the WEB. Set these to enable the web Apple
# button. APPLE_WEB_CLIENT_ID is the Apple Services ID; APPLE_WEB_REDIRECT_URI
# must match a Return URL registered for that Services ID (defaults to BASE_URL).
APPLE_WEB_CLIENT_ID=
APPLE_WEB_REDIRECT_URI=

# Content of Apple's domain-association file, served at
# /.well-known/apple-developer-domain-association.txt for Services ID domain
# verification.
APPLE_DOMAIN_ASSOCIATION=

# Optional email delivery. SES takes priority over SMTP.
AWS_SES_ACCESS_KEY=
AWS_SES_SECRET_KEY=
AWS_SES_REGION=us-east-1

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@example.com

# Optional Grafana password for monitoring compose files.
GRAFANA_ADMIN_PASSWORD=
